# App（单人自用可留空 AUTH_PASSWORD 免登录）
AUTH_PASSWORD=
WEB_PORT=8080
CORS_ORIGIN=http://localhost:5173
PORT=3001
WS_PORT=3002

# Chain
CHAIN_ID=56
MONITOR_WALLET=0xe45C0199A65f55CE2EfbB865025A52b3C75440BC
# 单人自用：只配一个 HTTPS 节点即可；多节点用逗号分隔（需 BSC_RPC_FAILOVER_ENABLED=true）
# 示例：NodeReal + 公共节点 + Owlracle + Nodies
# BSC_RPC_URLS=https://bsc-dataseed.bnbchain.org,https://binance-smart-chain-public.nodies.app
BSC_RPC_URLS=https://bsc-dataseed.bnbchain.org
BSC_RPC_FAILOVER_ENABLED=false
WSS_PRIMARY=wss://bsc.publicnode.com
# WSS_BACKUP=wss://bsc.drpc.org
# BSC_RPC_HEALTH_CHECK_INTERVAL_MS=60000

# PancakeSwap BSC
PANCAKE_FACTORY_ADDRESS=0xcA143Ce32Fe78f1f7019d1d19261165e12c7cE1C
PANCAKE_ROUTER_ADDRESS=0x10ED43C718714eb63d5aA57B78B54704E256024E

# Database（多服务共用 PostgreSQL，Docker Compose 会注入 DATABASE_URL）
DATABASE_URL=postgresql://monitor:monitor@localhost:5432/token_monitor
DATA_DIR=./data
# 可选只读副本（需 PG_READ_ENABLED=true）
# DATABASE_READ_URL=postgresql://monitor:monitor@localhost:5433/token_monitor
# PG_READ_ENABLED=true
# REDIS_URL=redis://localhost:6379
# dashboard_update 推送最小间隔（毫秒）
# DASHBOARD_PUSH_MS=15000

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TG_NOTIFY_ENABLED=true
# RPC 运维类告警（切换/限流/移除），默认不发 Telegram，避免刷屏
# TG_NOTIFY_RPC=true
# BSC_RPC_RATE_LIMIT_COOLDOWN_MS=900000
# BSC_RPC_REMOVE_RATE_LIMITED=false
TG_NOTIFY_LP_CREATED=true
TG_NOTIFY_LARGE_TRADE=true
TG_NOTIFY_LIQUIDITY=true
TG_NOTIFY_WHALE=true
TG_NOTIFY_PROJECT=true
LIQUIDITY_DROP_PCT=20

# Monitor tokens (copy data/monitor-tokens.example.json → data/monitor-tokens.json)
MONITOR_TOKENS_PATH=./data/monitor-tokens.json
MARKET_POLL_MS=60000
ALERT_LARGE_TRADE_USD=1000
WHALE_MIN_TRADE_USD=1000
WHALE_MIN_HOLDING_USD=5000
WHALE_MIN_HOLDING_PCT=0.5

# Worker → API 实时广播（Docker 默认由 compose 注入）
# REALTIME_BROADCAST_URL=http://api:3001/api/v1/internal/realtime

# Chain Listener 分层 getLogs
# fast_pair_listener: Pair Swap/Sync/Mint/Burn，默认每 2 块（安静时 5 块）
# medium_masterchef_listener: 质押合约，默认每 10 块（安静时 20 块）
# slow_transfer_listener: Token+LP Transfer，默认每 50 块（安静时 100 块）
# FAST_PAIR_INTERVAL_ACTIVE=2
# SLOW_TRANSFER_INTERVAL_ACTIVE=50
# SYNC_GETLOGS_MIN_INTERVAL_MS=400
# LISTENER_POLL_MS=4000
# LISTENER_STALE_HEARTBEAT_MS=180000
# LISTENER_HEALTH_CHECK_MS=60000
# LISTENER_POLL_FAST_MS=2000
# SYNC_TARGET_MAX_LAG_BLOCKS=20
# SYNC_CATCHUP_LAG_BLOCKS=20
# SYNC_CONFIRM_BLOCKS=1
# MARKET_RESERVES_CALIBRATE_MS=180000
# HOLDER_SKIP_BALANCEOF_ON_EVENT=true
# LISTENER_ENABLE_WSS_EVENTS=false

# Feature flags（当前阶段默认关闭 Farm / Staking / MasterChef）
ENABLE_MASTER_CHEF_LISTENER=false
ENABLE_AU_STAKING_LISTENER=false
ENABLE_CAT_FARM_LISTENER=false
ENABLE_TOKEN_TRANSFER_LISTENER=true
# RAW_EVENT_MAX_RETRIES=5
# RAW_EVENT_CONCURRENCY=6
# RAW_EVENT_BATCH_LIMIT=300
# WS_PRICE_UPDATE_MIN_MS=2000
# WS_HOLDER_UPDATE_MIN_MS=1500
# EVENT_PROCESSOR_POLL_MS=2000
# HOLDER_CALIBRATE_POLL_MS=60000
# HOLDER_CALIBRATE_BACKLOG_THRESHOLD=400
# DATA_MAINTENANCE_MS=300000
# DATA_MAINTENANCE_FULL_MS=21600000
# MONITOR_STARTUP_HOLDER_REPAIR=false
# LP_STAKE_LOG_RETRIES=3
# LP_STAKING_STAT_RECONCILE_MS=120000

# Frontend
VITE_DATA_POLL_MS=6000
