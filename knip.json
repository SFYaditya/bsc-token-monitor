{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["dotenv"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "frontend": {
      "entry": ["src/main.ts", "vite.config.ts"],
      "project": ["src/**/*.{ts,vue}"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "backend": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "chain-listener": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "event-processor": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "alert-worker": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": ["scripts/**"]
}
